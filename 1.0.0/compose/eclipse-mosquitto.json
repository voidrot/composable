{
  "name": "eclipse-mosquitto",
  "description": "Eclipse Mosquitto MQTT broker",
  "variables": {
    "MOSQUITTO_VERSION": "latest",
    "MOSQUITTO_MQTT_PORT": "1883",
    "MOSQUITTO_WS_PORT": "9001"
  },
  "configs": [
    {
      "source": "mosquitto-config.conf",
      "target": "config/mosquitto.conf"
    }
  ]
}
