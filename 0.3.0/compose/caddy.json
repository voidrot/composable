{
  "name": "caddy",
  "description": "Caddy web server with automatic HTTPS",
  "variables": {
    "CADDY_VERSION": "latest",
    "CADDY_HTTP_PORT": "80",
    "CADDY_HTTPS_PORT": "443",
    "CADDY_HTTPS_UDP_PORT": "443"
  },
  "configs": [
    {
      "source": "caddy-config.Caddyfile",
      "target": "config/Caddyfile"
    }
  ]
}
