{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the stack"
    },
    "description": {
      "type": "string",
      "description": "A brief description of the stack"
    },
    "fragments": {
      "type": "array",
      "description": "The fragments to add when initializing this stack",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "name": { "type": "string" },
          "customName": { "type": "string" },
          "env_overrides": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "depends_on": {
            "type": "object",
            "description": "Dependencies to inject into this fragment's compose service",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "condition": { "type": "string" }
              }
            }
          }
        },
        "required": ["type", "name"]
      }
    }
  },
  "required": ["name", "description", "fragments"]
}
