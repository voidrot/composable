{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "release-type": "node",
    "packages": {
        ".": {
            "release-type": "node",
            "exclude-paths": [
                "fragments",
                "registry",
                "src/registry",
                "docs",
                "stacks"
            ]
        },
        "fragments": {
            "release-type": "simple",
            "component": "fragments"
        },
        "stacks": {
            "release-type": "simple",
            "component": "stacks"
        }
    }
}