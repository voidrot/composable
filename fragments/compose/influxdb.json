{
  "name": "influxdb",
  "description": "InfluxDB time series database",
  "variables": {
    "INFLUXDB_VERSION": "2.8.0",
    "INFLUXDB_PORT": "8086",
    "INFLUXDB_ADMIN_USER": "admin",
    "INFLUXDB_ADMIN_PASSWORD": "adminpassword",
    "INFLUXDB_ORG": "myorg",
    "INFLUXDB_BUCKET": "mybucket",
    "INFLUXDB_ADMIN_TOKEN": "mysupersecrettoken"
